{
  "openapi": "3.1.0",
  "info": {
    "title": "Bug Test API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://httpbin.org",
      "description": "HTTPBin (echoes requests back)"
    }
  ],
  "paths": {
    "/post": {
      "post": {
        "operationId": "createItem",
        "summary": "Create Item (requestBody.required = true)",
        "description": "Tests CUS-1527: when requestBody.required is true and all fields are optional, submitting the empty form should send {} — not omit the body entirely.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Optional name field"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Optional email field"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Optional list of tags"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request echoed back by HTTPBin",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity — body was missing"
          }
        }
      }
    },
    "/items": {
      "post": {
        "operationId": "postItems",
        "summary": "Post Items (discriminator bug repro)",
        "description": "Reproduces the missing discriminator field bug. The generated cURL sample should include `platform` but omits it in client versions >= 0.0.2986.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateItemRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/get": {
      "get": {
        "operationId": "listItems",
        "summary": "List Items",
        "description": "Simple GET endpoint with no required body.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Max number of items to return"
          }
        ],
        "responses": {
          "200": {
            "description": "List of items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/sources": {
      "get": {
        "operationId": "listSources",
        "summary": "List Sources (root-level array response)",
        "description": "Repro for root-level array response not rendering in the API playground. The 200 response schema is `type: array` at the root — the playground should clearly show this is an array, but currently it doesn't.",
        "responses": {
          "200": {
            "description": "A list of sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Source"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateItemRequest": {
        "type": "object",
        "required": ["targets"],
        "properties": {
          "targets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TargetInput"
            }
          }
        }
      },
      "TargetInput": {
        "oneOf": [
          { "$ref": "#/components/schemas/AlphaInput" },
          { "$ref": "#/components/schemas/BetaInput" }
        ],
        "discriminator": {
          "propertyName": "platform",
          "mapping": {
            "ALPHA": "#/components/schemas/AlphaInput",
            "BETA": "#/components/schemas/BetaInput"
          }
        }
      },
      "AlphaPlatform": {
        "type": "object",
        "required": ["platform"],
        "properties": {
          "platform": {
            "type": "string",
            "enum": ["ALPHA"]
          }
        }
      },
      "BetaPlatform": {
        "type": "object",
        "required": ["platform"],
        "properties": {
          "platform": {
            "type": "string",
            "enum": ["BETA"]
          }
        }
      },
      "RequiredId": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string"
          }
        }
      },
      "AlphaInput": {
        "title": "Alpha",
        "allOf": [
          { "$ref": "#/components/schemas/AlphaPlatform" },
          { "$ref": "#/components/schemas/RequiredId" }
        ]
      },
      "BetaInput": {
        "title": "Beta",
        "allOf": [
          { "$ref": "#/components/schemas/BetaPlatform" },
          { "$ref": "#/components/schemas/RequiredId" }
        ]
      },
      "Source": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the source"
          },
          "name": {
            "type": "string",
            "description": "Display name of the source"
          },
          "type": {
            "type": "string",
            "enum": ["database", "file", "api"],
            "description": "The kind of source"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the source was created"
          }
        }
      }
    }
  }
}
